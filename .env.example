TELEGRAM_BOT_TOKEN_FRAKIR=

# provider can be "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional Cognee overrides. If omitted, the app maps OPENAI_API_KEY or
# ANTHROPIC_API_KEY into Cognee's LLM_API_KEY automatically.
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_API_KEY=

# Read-only source vault. This is intentionally never written to by the importer.
OBSIDIAN_VAULT_PATH=../../1.Stable/ExpressionVault
CHATGPT_EXPORT_PATH=
CLAUDE_EXPORT_PATH=
OPENCLAW_EXPORT_PATH=

# Local app data.
SQLITE_PATH=data/agent.sqlite
APPROVAL_POLICY_PATH=config/approvals.yaml

# Cognee durable storage. Defaults are project-local and ignored by git.
SYSTEM_ROOT_DIRECTORY=data/cognee/system
DATA_ROOT_DIRECTORY=data/cognee/storage
CACHE_ROOT_DIRECTORY=data/cognee/cache
COGNEE_LOGS_DIR=data/cognee/logs
