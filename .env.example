TELEGRAM_BOT_TOKEN_FRAKIR=

# provider can be "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional Cognee overrides. If omitted, the app maps OPENAI_API_KEY or
# ANTHROPIC_API_KEY into Cognee's LLM_API_KEY automatically.
LLM_API_KEY=
LLM_MODEL=
EMBEDDING_API_KEY=

# Read-only source vault. This is intentionally never written to by the importer.
OBSIDIAN_VAULT_PATH=../../1.Stable/ExpressionVault
CHATGPT_EXPORT_PATH=
CLAUDE_EXPORT_PATH=
OPENCLAW_EXPORT_PATH=
OPENCLAW_WORKSPACE_PATH=~/.openclaw/workspace
CLAUDE_PROJECTS_PATH=~/.claude/projects
CODEX_PROJECTS_PATH=~/.codex/projects
CLAUDE_PROJECT_MEMORY_PATH=~/.claude/projects/-Users-ok--openclaw-workspace/memory
OPENCLAW_SESSIONS_PATH=~/.openclaw/sessions
CLAUDE_GLOBAL_PATH=~/.claude/CLAUDE.md

# Local app data.
SQLITE_PATH=data/agent.sqlite
APPROVAL_POLICY_PATH=config/approvals.yaml

# Cognee durable storage. Defaults are project-local and ignored by git.
SYSTEM_ROOT_DIRECTORY=data/cognee/system
DATA_ROOT_DIRECTORY=data/cognee/storage
CACHE_ROOT_DIRECTORY=data/cognee/cache
COGNEE_LOGS_DIR=data/cognee/logs

# Optional OpenClaw delegation. The bot calls this only through the approval queue.
OPENCLAW_CLI_PATH=openclaw
OPENCLAW_AGENT_ID=
OPENCLAW_LOCAL=true
OPENCLAW_TIMEOUT_SECONDS=600

# Focused context budget for normal Telegram answers.
FOCUSED_CONTEXT_ITEMS=4
FOCUSED_CONTEXT_CHARS=2200
FOCUSED_MEMORY_ITEM_CHARS=500
CORE_MEMORY_CHARS=3500
CORE_MEMORY_AUTO_UPDATE=true

# Optional Letta server-backed core memory blocks. If disabled, Frakir uses
# local SQLite core memory blocks with the same labels.
LETTA_ENABLED=false
LETTA_API_KEY=
LETTA_BASE_URL=
LETTA_AGENT_ID=

# Optional local Apple Intelligence summarization before Cognee ingest.
# By default, large Claude Code project/session files are summarized locally
# with apfel so Cognee indexes compact memory instead of raw transcripts.
APFEL_CLI_PATH=apfel
APFEL_SUMMARY_SOURCES=claude_projects
APFEL_SUMMARY_MIN_CHARS=8000
APFEL_SUMMARY_CHUNK_CHARS=1800
APFEL_SUMMARY_MAX_CHUNKS=12
APFEL_SUMMARY_TIMEOUT_SECONDS=180
APFEL_ROLLING_SUMMARY_MAX_CHARS=1800
APFEL_TRANSLATE_UNSUPPORTED_LANGUAGE=true
APFEL_LLM_FALLBACK_ON_UNSUPPORTED_LANGUAGE=true
